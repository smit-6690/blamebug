# Required: Groq API key (https://console.groq.com/keys) — OpenAI-compatible endpoint
#GROQ_API_KEY=YOUR_GROQ_API_KEY

# Optional: override model (default with Groq: llama-3.3-70b-versatile)
# FAULTLINE_LLM_MODEL=llama-3.3-70b-versatile
# Backward compatible: BLAMEBUG_LLM_MODEL is also supported

# Alternative: use OpenAI instead of Groq (omit GROQ_API_KEY or set OPENAI_BASE_URL)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: require this value in header X-FaultLine-Secret on POST /api/webhook
# FAULTLINE_WEBHOOK_SECRET=your-shared-secret
# Backward compatible: BLAMEBUG_WEBHOOK_SECRET is also supported